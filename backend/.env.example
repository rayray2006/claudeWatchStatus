# Postgres — Neon, Supabase, or local. Must be sslmode=require for serverless.
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# Session JWT signing — random 32+ byte base64 string
SESSION_SECRET=

# APNs production credentials (App Store build)
# Generate .p8 file at developer.apple.com/account/resources/authkeys/list
APNS_KEY_ID=
APNS_TEAM_ID=
# Paste the full .p8 file contents including BEGIN/END markers
APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
...
-----END PRIVATE KEY-----"

# APNs target environment: 'production' or 'sandbox'.
# Release builds use production. TestFlight still uses production.
APNS_ENV=sandbox

# Watch app bundle id — determines apns-topic
BUNDLE_ID=com.fm.claudetap.watchapp

# Apple Sign-In — audience is the iOS app bundle id
APPLE_AUDIENCE=com.fm.claudetap
